        <field name="TEMPOTOTAL" systemField="N" dataType="S" presentationType="H" calculated="N" allowSearch="N" allowDefault="S" visibleOnSearch="S" allowNull="S">
          <description><![CDATA[Tempo total]]></description>
          <expression><![CDATA[if ($col_DTINICIO != null && $col_DTFIM != null) {
    // Calcula a diferença em milissegundos
    long ini = $col_DTINICIO.getTime();
    long fim = $col_DTFIM.getTime();
    long diff = fim - ini;
    
    // Converte para minutos totais
    long totalMinutos = diff / 60000;
    
    // Calcula Horas e Minutos separadamente
    long h = totalMinutos / 60;
    long m = totalMinutos % 60;

    // Monta a String com zero à esquerda manualmente
    String sh = (h < 10) ? "0" + h : "" + h;
    String sm = (m < 10) ? "0" + m : "" + m;
    
    String tempoFormatado = sh + ":" + sm;

    // Retorna o HTML para o Sankhya exibir formatado
    return "<b><span style='color: #00008B; font-size: 12px;'>" + tempoFormatado + "</span></b>";
}
return null;]]></expression>
