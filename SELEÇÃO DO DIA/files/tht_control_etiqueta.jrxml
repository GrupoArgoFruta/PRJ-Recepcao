<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="tht_control_etiqueta" pageWidth="396" pageHeight="283" orientation="Landscape" whenNoDataType="NoDataSection" columnWidth="396" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0">
	<property name="ireport.zoom" value="3.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<property name="ireport.definition"/>
	<parameter name="PK_SEQUENCIA" class="java.math.BigDecimal" isForPrompting="false">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    SEL.SEQUENCIA,
    SEL.IDGAIOLA,
    SEL.TEMPO,
    SEL.TANQUE,
    TO_CHAR(SEL.DTSELECAO, 'DD/MM/YYYY')  AS DTSELECAO,
    OPTION_LABEL('AD_ROMANEIOENTSELCDIA','MERCADO', SEL.MERCADO) AS DESC_MERCADO,
    ITM.NROUNICO,
    ITM.SEQITEM,
    ITM.UP,
    PAR.NOMEPARC         AS PRODUTOR,
    GRU.AD_DESCRESUMO    AS VARIEDADE,
(SELECT LISTAGG(I.CALIBRE, ' | ') WITHIN GROUP (ORDER BY I.SEQITEM)
     FROM AD_THTLOTEITEM I
     WHERE I.SEQUENCIA = SEL.SEQUENCIA) AS CALIBRE,
    (SELECT
    'SEQ:' || TO_CHAR(SEL.SEQUENCIA)
    || '|Gaiola:' || NVL(TO_CHAR(SEL.IDGAIOLA), '-')
    || '|Mercado:' || NVL(OPTION_LABEL('AD_ROMANEIOENTSELDIA','MERCADO', SEL.MERCADO), '-')
    || '|Tanque:' || NVL(TO_CHAR(SEL.TANQUE), '-')
    || '|Tempo:' || NVL(TO_CHAR(SEL.TEMPO), '-') || 'min'
    || '|Selecao:' || NVL(TO_CHAR(SEL.DTSELECAO, 'DD/MM/YYYY'), '-')
    || '|Itens:' || LISTAGG(
        'ROM:' || TO_CHAR(I2.NROUNICO)
        || ';Prod:' || NVL(P2.NOMEPARC, '-')
        || ';Var:' || NVL(G2.AD_DESCRESUMO, '-')
        || ';Cont:' || NVL(TO_CHAR(I2.QTDCONT), '0')
        || ';Pos:' || NVL(TO_CHAR(I2.POSINICIO), '') || '-' || NVL(TO_CHAR(I2.POSFIM), '')
    , '||') WITHIN GROUP (ORDER BY I2.SEQITEM)
FROM AD_THTLOTEITEM I2
LEFT JOIN AD_ROMANEIOENTR E2 ON I2.NROUNICO = E2.NROUNICO
LEFT JOIN TGFPAR P2 ON E2.CODPARC = P2.CODPARC
LEFT JOIN TGFPRO PR2 ON E2.CODPROD = PR2.CODPROD
LEFT JOIN TGFGRU G2 ON PR2.CODGRUPOPROD = G2.CODGRUPOPROD
WHERE I2.SEQUENCIA = SEL.SEQUENCIA
) AS QR_DATA
FROM AD_ROMANEIOENTSELCDIA SEL
INNER JOIN AD_THTLOTEITEM ITM ON SEL.SEQUENCIA = ITM.SEQUENCIA
LEFT JOIN AD_ROMANEIOENTR ENT ON ITM.NROUNICO = ENT.NROUNICO
LEFT JOIN TGFPAR PAR ON ENT.CODPARC = PAR.CODPARC
LEFT JOIN TGFPRO PRO ON ENT.CODPROD = PRO.CODPROD
LEFT JOIN TGFGRU GRU ON PRO.CODGRUPOPROD = GRU.CODGRUPOPROD
WHERE SEL.SEQUENCIA = $P{PK_SEQUENCIA}
ORDER BY ITM.SEQITEM]]>
	</queryString>
	<field name="SEQUENCIA" class="java.math.BigDecimal"/>
	<field name="IDGAIOLA" class="java.lang.String"/>
	<field name="TEMPO" class="java.math.BigDecimal"/>
	<field name="DTSELECAO" class="java.lang.String"/>
	<field name="DESC_MERCADO" class="java.lang.String"/>
	<field name="NROUNICO" class="java.math.BigDecimal"/>
	<field name="SEQITEM" class="java.math.BigDecimal"/>
	<field name="UP" class="java.lang.String"/>
	<field name="PRODUTOR" class="java.lang.String"/>
	<field name="VARIEDADE" class="java.lang.String"/>
	<field name="QR_DATA" class="java.lang.String"/>
	<field name="CALIBRE" class="java.lang.String"/>
